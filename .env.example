# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's already in .gitignore

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found at: dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Found at: dashboard.stripe.com → Products → your Pro product → price ID
VITE_STRIPE_PRO_PRICE_ID=price_...
# Also set this as a Supabase secret for server-side price validation:
# supabase secrets set STRIPE_PRO_PRICE_ID=price_...
# Found at: dashboard.stripe.com → Products → your Education product → price ID ($200/mo)
VITE_STRIPE_EDUCATION_PRICE_ID=price_...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# NOT a VITE_ variable — keep this as a Supabase backend secret ONLY.
# Run: supabase secrets set OPENAI_API_KEY=sk-...
# Found at: platform.openai.com → API keys
# NEVER add this to .env or expose it to the browser.
